# NASA API (получить на https://api.nasa.gov)
NASA_API_KEY=DEMO_KEY
NASA_URL=https://api.nasa.gov
# На сайте Nasa есть разделы со следующей информацией:
# NeoWs - астероиды
# DONKI - солнечная активность
# APOD  - фото дня

# The Space Devs (бесплатно, без ключа, но лучше зарегистрироваться)
SPACE_DEVS_URL=https://ll.thespacedevs.com/2.3.0/
# запуски ракет

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key